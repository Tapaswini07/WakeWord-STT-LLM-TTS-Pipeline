# Voice Assistant Configuration
# Get free API keys from the links below

# Option 1: Groq (Recommended - Fastest)
# Get free key: https://console.groq.com
# Provide free API key here:
GROQ_API_KEY=

# Option 2: HuggingFace 
# Get free key: https://huggingface.co/settings/tokens
HF_API_KEY=

# Ollama configuration (if using local Ollama)
LLM_ENDPOINT=http://localhost:11434/api/generate

# Optional: Enable for detailed logging
VERBOSE_LOGGING=true
ENABLE_LATENCY_MEASUREMENT=true

# LLM Provider selection
LLM_PROVIDER=gemini