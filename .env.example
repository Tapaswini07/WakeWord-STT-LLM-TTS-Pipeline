# Voice Assistant Environment Configuration

# API Keys (Get free keys from below)
GROQ_API_KEY=your_groq_api_key_here
# Get Groq API key: https://console.groq.com

HF_API_KEY=your_huggingface_api_key_here
# Get HuggingFace API key: https://huggingface.co/settings/tokens

# Ollama Configuration (if using local LLM)
LLM_ENDPOINT=http://localhost:11434/api/generate
LLM_MODEL=neural-chat

# Optional configurations
VERBOSE_LOGGING=true
ENABLE_LATENCY_MEASUREMENT=true
